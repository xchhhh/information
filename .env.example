# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交）

# DeepSeek 密钥：本地开发与后端生成答案都靠它（必填）
LLM_API_KEY=sk-你的deepseek密钥

# 火山方舟 doubao embedding 密钥：部署到云端、且 embedding.provider=doubao 时填（本地 Ollama 不需要）
ARK_API_KEY=你的火山方舟密钥

# Langfuse 可观测：可选，仅在 settings.yaml 中 langfuse.enabled=true 时填写
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
